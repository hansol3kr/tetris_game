# ============================================================================
#  Blockfall — App Store Connect API 키 (iOS 로컬 업로드용)
# ============================================================================
#  이 파일을  ios/appstore_connect.env  로 "복사"한 뒤 값을 채우세요.
#  진짜 파일(ios/appstore_connect.env)과 .p8 키는 .gitignore 로 커밋이 막혀 있습니다 —
#  절대 커밋/공유하지 마세요. (이 .example 템플릿만 저장소에 올라갑니다.)
#
#  ⚠ CI(Codemagic)로 빌드한다면 이 파일이 필요 없습니다. Codemagic 은 같은 키를
#     웹 UI 볼트에 보관하고 codemagic.yaml 의
#     integrations.app_store_connect: blockfall_asc 로 참조합니다.
#     이 로컬 파일은 "로컬 Mac 에서 커맨드라인으로 TestFlight 업로드"(ios/upload.sh)
#     할 때만 씁니다. 전체 절차: docs/IOS_RELEASE.md
#
#  값 얻는 법 — App Store Connect (https://appstoreconnect.apple.com)
#    → Users and Access → Integrations → App Store Connect API → Team Keys → ＋
#    (Access: App Manager):
#      • Issuer ID : 화면 상단의 UUID
#      • Key ID    : 생성된 키의 10자리 ID
#      • .p8 파일  : 생성 시 딱 1회 다운로드 → ios/private_keys/AuthKey_<KeyID>.p8 에 저장
#    Team ID — developer.apple.com/account → Membership → Team ID (10자리)
# ============================================================================

# App Store Connect API — Issuer ID (UUID)
ASC_ISSUER_ID=""

# App Store Connect API — Key ID (10자리, AuthKey_<KeyID>.p8 의 <KeyID> 와 동일)
ASC_KEY_ID=""

# .p8 개인키 경로 (저장소 루트 기준). ios/private_keys/ 에 넣으세요.
# <KeyID> 자리를 위 Key ID 로 바꾸면 됩니다.
ASC_PRIVATE_KEY_PATH="ios/private_keys/AuthKey_<KeyID>.p8"

# Apple Developer Team ID (10자리) — build-ios.sh 가 익스포트 프리셋에 자동 주입.
ASC_TEAM_ID=""

# 앱 번들 ID (App Store Connect + iOS 익스포트 프리셋과 반드시 동일해야 함).
ASC_BUNDLE_ID="com.blockfall.game"
